generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")  // ✅ Wajib untuk migration di PostgreSQL
}

// --- ENUMS ---

enum StatusPesan {
  Menunggu_Konfirmasi
  Sedang_Diproses
  Menunggu_Kurir
  Selesai
}

enum StatusKirim {
  Sedang_Dikirim
  Tiba_Ditujuan
}

enum LevelUser {
  admin
  owner
  kurir
}

enum JenisPaket {
  Prasmanan
  Box
}

enum KategoriPaket {
  Pernikahan
  Selamatan
  Ulang_Tahun
  Studi_Tour
  Rapat
}

// --- MODELS ---

model User {
  id        BigInt    @id @default(autoincrement())
  name      String    @db.VarChar(30)
  email     String    @unique @db.VarChar(255)
  password  String    @db.VarChar(255)
  level     LevelUser @default(admin)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  pengirimans Pengiriman[]

  @@map("users")
}

model Pelanggan {
  id             BigInt    @id @default(autoincrement())
  nama_pelanggan String    @db.VarChar(100)
  email          String    @unique @db.VarChar(255)
  password       String    @db.VarChar(255)
  tgl_lahir      DateTime? @db.Date
  telepon        String    @db.VarChar(15)
  alamat1        String    @db.VarChar(255)
  alamat2        String?   @db.VarChar(255)
  alamat3        String?   @db.VarChar(255)
  kartu_id       String?   @db.VarChar(255)
  foto           String?   @db.VarChar(255)
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  pemesanans Pemesanan[]

  @@map("pelanggans")
}

model JenisPembayaran {
  id                 BigInt    @id @default(autoincrement())
  metode_pembayaran  String    @unique @db.VarChar(30)
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  pemesanans         Pemesanan[]
  detail_pembayarans DetailJenisPembayaran[]

  @@map("jenis_pembayarans")
}

model DetailJenisPembayaran {
  id                    BigInt   @id @default(autoincrement())
  id_jenis_pembayaran   BigInt
  no_rek                String   @db.VarChar(25)
  tempat_bayar          String   @db.VarChar(50)
  logo                  String?  @db.VarChar(255)
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  jenis_pembayaran JenisPembayaran @relation(fields: [id_jenis_pembayaran], references: [id])

  @@index([id_jenis_pembayaran])
  @@map("detail_jenis_pembayarans")
}

model Paket {
  id           BigInt        @id @default(autoincrement())
  nama_paket   String        @db.VarChar(50)
  jenis        JenisPaket
  kategori     KategoriPaket
  jumlah_pax   Int           // ✅ PostgreSQL auto-detect, tidak perlu @db.Integer
  harga_paket  Int           // ✅ PostgreSQL auto-detect
  deskripsi    String?       @db.Text
  foto1        String?       @db.VarChar(255)
  foto2        String?       @db.VarChar(255)
  foto3        String?       @db.VarChar(255)
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt

  detail_pemesanans DetailPemesanan[]

  @@map("pakets")
}

model Pemesanan {
  id            BigInt       @id @default(autoincrement())
  id_pelanggan  BigInt
  id_jenis_bayar BigInt
  no_resi       String?      @db.VarChar(30) @unique  // ✅ Spasi diperbaiki
  tgl_pesan     DateTime     @default(now()) @db.Timestamp(3) // ✅ Lebih presisi di Postgres
  status_pesan  StatusPesan  @default(Menunggu_Konfirmasi)
  total_bayar   BigInt
  created_at    DateTime     @default(now())
  updated_at    DateTime     @updatedAt

  pelanggan     Pelanggan          @relation(fields: [id_pelanggan], references: [id])
  jenis_bayar   JenisPembayaran    @relation(fields: [id_jenis_bayar], references: [id])
  detail        DetailPemesanan[]
  pengiriman    Pengiriman?

  @@index([id_pelanggan])
  @@index([id_jenis_bayar])
  @@map("pemesanans")
}

model DetailPemesanan {
  id_pemesanan  BigInt
  id_paket      BigInt
  subtotal      BigInt
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  pemesanan Pemesanan @relation(fields: [id_pemesanan], references: [id])
  paket     Paket     @relation(fields: [id_paket], references: [id])

  @@id([id_pemesanan, id_paket])  // ✅ Composite key tetap sama
  @@index([id_paket])
  @@map("detail_pemesanans")
}

model Pengiriman {
  id           BigInt       @id @default(autoincrement())
  tgl_kirim    DateTime?    @db.Timestamp(3)
  tgl_terima   DateTime?    @db.Timestamp(3)
  status_kirim StatusKirim  @default(Sedang_Dikirim)
  bukti_foto   String?      @db.VarChar(255)
  id_pesan     BigInt       @unique
  id_user      BigInt
  created_at   DateTime     @default(now())
  updated_at   DateTime     @updatedAt

  pemesanan Pemesanan @relation(fields: [id_pesan], references: [id])
  user      User      @relation(fields: [id_user], references: [id])

  @@index([id_user])
  @@map("pengirimans")
}